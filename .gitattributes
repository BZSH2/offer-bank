# Normalize text files to LF by default.
* text=auto eol=lf

# Keep Git hook files Unix-friendly.
.husky/* text eol=lf

# Common Windows shell entrypoints can keep CRLF if added later.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Common binary assets.
*.ico binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.avif binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.pdf binary
*.zip binary
