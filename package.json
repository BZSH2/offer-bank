{
  "name": "offer-bank",
  "private": true,
  "version": "0.1.0",
  "description": "Full-stack offer bank monorepo foundation.",
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "lint": "pnpm lint:eslint && pnpm lint:stylelint && pnpm lint:markdown",
    "lint:eslint": "eslint . --max-warnings=0",
    "lint:stylelint": "stylelint \"apps/**/*.{css,scss,vue}\" --allow-empty-input",
    "lint:markdown": "markdownlint-cli2 \"**/*.{md,mdx}\" \"!**/node_modules/**\" \"!**/dist/**\"",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "pnpm -r --if-present typecheck",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck",
    "lint:staged": "lint-staged"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.25.1",
    "@types/node": "^24.0.1",
    "@vitejs/plugin-vue": "^5.2.4",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-vue": "^9.33.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "markdownlint-cli2": "^0.18.1",
    "postcss-html": "^1.7.0",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.5.3",
    "sass": "^1.89.0",
    "stylelint": "^17.5.0",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.0.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.1",
    "vite": "^5.4.19",
    "vue-eslint-parser": "^10.1.0",
    "vue-tsc": "^2.2.8"
  }
}
